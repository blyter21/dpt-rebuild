# DPT future Supabase/Vercel environment template
# Template only. Do not fill with production credentials unless Brook explicitly approves cloud wiring.

# Explicit source-mode switch. Without this exact value, apps/site uses JSON fallback.
DPT_DATA_SOURCE=supabase

# Supabase public project URL and anon key for public read-only tables/views.
# Use local Supabase values first, then preview/staging, then production only after approval.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-or-preview-anon-key

# Optional final public media base URL after uploading/copying local media.
# Leave blank until final storage/CDN is selected.
NEXT_PUBLIC_DPT_MEDIA_BASE_URL=https://cdn.example.com/dpt-public-media

# Optional server-side aliases for the same values if a server-only runtime prefers them.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-local-or-preview-anon-key

# Vercel should receive the same public env vars for preview/prod.
# No service-role key is needed for public-read site pages.
# Never commit real keys.
