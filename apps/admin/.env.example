# DPT admin prototype local transport config
# Safe default: local mock route layer. No Supabase connection.
NEXT_PUBLIC_DPT_ADMIN_API_TRANSPORT=mock-route

# Supabase transport requires a two-step opt-in and remains unused unless this is exactly true.
# Keep false/unset for local mock work.
NEXT_PUBLIC_DPT_ENABLE_SUPABASE_TRANSPORT=false

# Future local Supabase values only. Do not add production credentials here.
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-dev-anon-key
