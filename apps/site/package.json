{
  "name": "@dpt/site-replacement",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "extract:data": "python3 ../../scripts/extract_public_dpt_data.py",
    "media:manifest": "python3 ../../scripts/build_dpt_media_manifest.py",
    "prepare:data": "npm run extract:data && npm run media:manifest && python3 ../../scripts/build_dpt_media_storage_plan.py",
    "dev": "next dev -p 3001",
    "build": "npm run prepare:data && next build",
    "start": "next start -p 3001",
    "typecheck": "tsc --noEmit",
    "test": "npm run prepare:data && vitest run"
  },
  "dependencies": {
    "@dpt/tournament-engine": "0.0.1",
    "next": "^14.2.24",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
