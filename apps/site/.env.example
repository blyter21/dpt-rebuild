# DPT public replacement site local defaults
# Safe local mode: generated SQL-backed JSON + local copied media.

DPT_DATA_SOURCE=json

# Optional future media base URL. Leave blank for local /media/dpt assets.
NEXT_PUBLIC_DPT_MEDIA_BASE_URL=

# Supabase values intentionally omitted in local JSON mode.
# See ../../.env.supabase.example for the explicit Supabase opt-in template.
