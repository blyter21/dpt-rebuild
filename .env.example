# DPT rebuild lab default local environment
# Safe default: JSON/local generated data, no cloud calls, no deploy.

DPT_DATA_SOURCE=json

# Optional future media base URL. Leave blank for local /media/dpt assets.
# Example: https://cdn.example.com/dpt-public-media
NEXT_PUBLIC_DPT_MEDIA_BASE_URL=

# Optional local dev server port used by apps/site
PORT=3001

# Do not put production credentials in this file.
